{
  "enabledPlugins": {
    "claude-md-management@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_FILE_PATH\" | grep -qE '\\.env($|\\.local|\\.*)'; then echo 'BLOCK: Do not edit .env files — they contain secrets'; exit 1; fi"
          }
        ]
      }
    ]
  }
}
